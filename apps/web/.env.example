# Database (MySQL — same as bot, shared DB)
# Local:      mysql://numninjas:password@localhost:3306/numninjas
# Production: mysql://user:password@127.0.0.1:3306/num_ninjas  (use 127.0.0.1 on Hostinger, NOT srvXXXX.hstgr.io)
DATABASE_URL=mysql://numninjas:password@localhost:3306/numninjas

# Auth.js secret (generate with: openssl rand -base64 32)
AUTH_SECRET=change-me-in-production

# Auth.js canonical URL — required in production so Auth.js knows the public domain.
# Without this, login breaks behind Cloudflare with "UntrustedHost" errors.
AUTH_URL=https://your-domain.com

# Environment (set to 'production' on Hostinger)
NODE_ENV=development

# Port the standalone Next.js server binds to.
# Hostinger's Node.js setup REQUIRES this — without it the server picks a
# random port and the proxy fails. Standard production value is 3000.
PORT=3000
