# This monorepo uses per-app .env files (not a root .env):
#
# packages/database/.env  — DATABASE_URL (for Prisma CLI commands)
# apps/bot/.env            — BOT_TOKEN, ADMIN_TELEGRAM_ID, DATABASE_URL
# apps/web/.env.local      — DATABASE_URL, AUTH_SECRET
#
# Copy each .env.example to the correct location:
#   cp packages/database/.env.example packages/database/.env
#   cp apps/bot/.env.example apps/bot/.env
#   cp apps/web/.env.example apps/web/.env.local
