generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── Accounts & Profiles ────────────────────────────────────────────

model Account {
  telegramId      BigInt    @id @map("telegram_id")
  activeProfileId Int?      @unique @map("active_profile_id")
  lastNudgeAt     DateTime? @map("last_nudge_at") // set once when we send the onboarding-abandon nudge; never re-sent (see engagement-nudge.service.ts)
  blockedAt       DateTime? @map("blocked_at")    // NULL = reachable; set when the user blocks the bot (via my_chat_member or a 403 send-failure); cleared back to NULL on unblock
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  activeProfile User?  @relation("ActiveProfile", fields: [activeProfileId], references: [id])
  users         User[] @relation("AccountUsers")

  @@index([blockedAt])
  @@map("accounts")
}

model User {
  id           Int       @id @default(autoincrement())
  accountId    BigInt    @map("account_id")
  nickname     String
  username     String?   @unique
  locale       String    @default("ar") // "ar" or "en"
  isPublic     Boolean   @default(true) @map("is_public") // false = profile hidden from leaderboard links
  levelId      Int       @map("level_id")
  streakDays   Int       @default(0) @map("streak_days")
  totalPoints  Int       @default(0) @map("total_points")
  lastActiveAt DateTime? @map("last_active_at")
  lastNudgeAt  DateTime? @map("last_nudge_at") // last time we sent a never-engaged or went-silent nudge; a new inactivity streak unlocks a fresh nudge (see engagement-nudge.service.ts)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  account          Account          @relation("AccountUsers", fields: [accountId], references: [telegramId])
  activeForAccount Account?         @relation("ActiveProfile")
  level            Level            @relation(fields: [levelId], references: [id])
  studySessions      StudySession[]
  questionAttempts   QuestionAttempt[]
  userBadges         UserBadge[]
  scheduledQuestions  ScheduledQuestion[]

  @@index([accountId])
  @@index([levelId])
  @@map("users")
}

// ─── Levels & Topics ────────────────────────────────────────────────

model Level {
  id            Int      @id @default(autoincrement())
  name          String
  nameEn        String?  @map("name_en") // English name (for i18n)
  rankOrder     Int      @map("rank_order")
  description   String?
  descriptionEn String?  @map("description_en") // English description (for i18n)
  iconEmoji     String?  @map("icon_emoji")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  topics             Topic[]
  users              User[]

  @@map("levels")
}

model Topic {
  id            Int      @id @default(autoincrement())
  levelId       Int      @map("level_id")
  name          String
  nameEn        String?  @map("name_en") // English name (for i18n)
  description   String?
  descriptionEn String?  @map("description_en") // English description (for i18n)
  orderInLevel  Int      @default(1) @map("order_in_level")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  level     Level      @relation(fields: [levelId], references: [id])
  questions Question[]

  @@map("topics")
}

// ─── Questions & Options ────────────────────────────────────────────

model Question {
  id                   Int      @id @default(autoincrement())
  topicId              Int      @map("topic_id")
  questionType         String   @map("question_type") // "mcq" | "open_ended"
  locale               String   @default("ar") // "ar" or "en"
  realLifeContext      String?  @map("real_life_context")
  questionText         String   @map("question_text")
  correctAnswer        String?  @map("correct_answer")
  correctAnswerNumeric Float?   @map("correct_answer_numeric")
  hintText             String?  @map("hint_text")
  explanation          String
  imageUrl             String?  @map("image_url")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  topic              Topic              @relation(fields: [topicId], references: [id])
  options            Option[]
  questionAttempts   QuestionAttempt[]
  scheduledQuestions ScheduledQuestion[]

  @@index([topicId, locale])
  @@index([topicId])
  @@index([locale])
  @@map("questions")
}

model Option {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  optionText String   @map("option_text")
  isCorrect  Boolean  @default(false) @map("is_correct")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id])

  @@map("options")
}

// ─── Scheduling ─────────────────────────────────────────────────────

model ScheduledQuestion {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  questionId    Int      @map("question_id")
  position      Int
  scheduledDate DateTime @map("scheduled_date")
  createdAt     DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@unique([userId, position, scheduledDate], name: "user_position_date")
  @@index([scheduledDate])
  @@map("scheduled_questions")
}

// ─── Sessions & Attempts ────────────────────────────────────────────

model StudySession {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  sessionDate       DateTime @map("session_date")
  questionsSent     Int      @default(0) @map("questions_sent")
  questionsAnswered Int      @default(0) @map("questions_answered")
  isComplete        Boolean  @default(false) @map("is_complete")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, sessionDate], name: "user_session_date")
  @@index([sessionDate])
  @@map("study_sessions")
}

model QuestionAttempt {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  userAnswer String?  @map("user_answer")
  isCorrect  Boolean  @default(false) @map("is_correct")
  hintUsed   Boolean  @default(false) @map("hint_used")
  answeredAt DateTime @default(now()) @map("answered_at")

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, answeredAt])
  @@index([questionId])
  @@map("question_attempts")
}

// ─── Badges ─────────────────────────────────────────────────────────

model Badge {
  id             Int      @id @default(autoincrement())
  name           String
  nameEn         String?  @map("name_en") // English name (for i18n)
  awardTitle     String?  @map("award_title")
  awardTitleEn   String?  @map("award_title_en") // English award title (for i18n)
  description    String?
  descriptionEn  String?  @map("description_en") // English description (for i18n)
  iconEmoji      String?  @map("icon_emoji")
  badgeType      String   @map("badge_type") // "achievement" | "weekly_rank" | "monthly_rank" | "yearly_rank"
  rankPosition   Int?     @map("rank_position")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  badgeId       Int      @map("badge_id")
  periodLabel     String   @map("period_label")
  periodLabelEn   String?  @map("period_label_en")
  periodStart     DateTime @map("period_start")
  metricSummary   String?  @map("metric_summary")
  metricSummaryEn String?  @map("metric_summary_en")
  earnedAt        DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId, periodStart], name: "user_badge_period")
  @@map("user_badges")
}

// ─── App Settings ───────────────────────────────────────────────────

model Setting {
  id            Int      @id @default(autoincrement())
  settingKey    String   @unique @map("setting_key")
  value         String
  type          String   @default("string") // "integer" | "string" | "time" | "boolean"
  description   String?
  descriptionEn String?  @map("description_en") // English description (for i18n)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ─── Cron Observability ─────────────────────────────────────────────

/// Records every execution of a scheduled or manually-triggered job so we
/// can answer "did the 14:30 send actually run today?" without grepping
/// logs. Written by withCronRun() in cron-run.service.ts. Old rows are
/// pruned by the weekly cleanup job (default retention 30 days) so this
/// table stays bounded even on busy deployments.
model CronRun {
  id           Int       @id @default(autoincrement())
  name         String    // 'sendFirstQuestion', 'prepareScheduledQuestions', etc.
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")  // null while still running
  success      Boolean   @default(false)       // true after a clean finish
  durationMs   Int?      @map("duration_ms")  // finishedAt - startedAt, in ms
  statsJson    String?   @db.Text @map("stats_json")     // structured counts/metrics from the job
  errorMessage String?   @db.Text @map("error_message")  // truncated error string on failure

  @@index([name, startedAt(sort: Desc)])  // "latest run of job X"
  @@index([startedAt])                     // retention cleanup
  @@map("cron_runs")
}

// ─── Admin Users ────────────────────────────────────────────────────

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admins")
}
