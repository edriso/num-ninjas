{
  "name": "num-ninjas",
  "private": true,
  "scripts": {
    "dev:bot": "pnpm --filter bot dev",
    "build:bot": "pnpm --filter bot build",
    "build:web": "packages/database/node_modules/.bin/prisma generate --schema=packages/database/prisma/schema.prisma && cd apps/web && node_modules/.bin/next build && cp -r .next/static .next/standalone/apps/web/.next/static && cp -r public .next/standalone/apps/web/public",
    "db:generate": "pnpm --filter @numninjas/database db:generate",
    "db:push": "pnpm --filter @numninjas/database db:push",
    "db:seed": "pnpm --filter @numninjas/database db:seed",
    "db:seed:demo": "pnpm --filter @numninjas/database db:seed:demo",
    "db:reset": "pnpm --filter @numninjas/database db:reset",
    "test": "pnpm --filter @numninjas/database test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
