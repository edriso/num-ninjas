{
  "name": "num-ninjas",
  "version": "1.0.0",
  "description": "\u0646\u064a\u0646\u062c\u0627 \u0627\u0644\u0623\u0631\u0642\u0627\u0645 \u2014 Telegram math bot for Egyptian students",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "lint": "eslint src/",
    "format": "prettier --write ."
  },
  "keywords": [
    "telegram",
    "bot",
    "math",
    "education",
    "arabic"
  ],
  "author": "Mohamed Idris",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.0",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}